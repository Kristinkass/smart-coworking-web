<mxfile host="app.diagrams.net" agent="design-export" version="22.1.0" type="device">
  <diagram id="bpmn-login" name="Вход в систему">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1760" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
