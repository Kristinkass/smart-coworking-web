            <mxPoint x="260" y="310" as="sourcePoint" />
            <mxPoint x="1340" y="310" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="zone_line2" parent="1" style="endArrow=none;html=1;strokeWidth=1;dashed=1;" edge="1">
